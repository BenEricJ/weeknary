# Copy this file to .env.local and fill values locally.
# Do not commit real Supabase tokens, database passwords, or test-user passwords.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-supabase-db-password

WEEKNARY_TEST_USER_A_EMAIL=user-a@example.com
WEEKNARY_TEST_USER_A_PASSWORD=replace-with-local-password
WEEKNARY_TEST_USER_B_EMAIL=user-b@example.com
WEEKNARY_TEST_USER_B_PASSWORD=replace-with-local-password

# Supabase Edge Function secrets. Set these with `npx supabase secrets set ...`;
# do not expose them through Vite client-side env variables.
OPENAI_API_KEY=replace-with-local-openai-api-key
OPENAI_MODEL=gpt-5.2
PLAN_GENERATION_TIMEOUT_MS=60000

# Optional local Edge Function development switch.
WEEKNARY_PLAN_GENERATION_MOCK=false
